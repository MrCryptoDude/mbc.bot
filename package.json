{
  "name": "mbc-bot",
  "version": "1.0.0",
  "description": "MEME•BACKED•CURRENCY — AI Dungeon Master Twitter Bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "post-now": "ts-node src/index.ts post-now",
    "dnd-now": "ts-node src/index.ts dnd-now",
    "status": "ts-node src/index.ts status",
    "reset": "ts-node src/index.ts reset",
    "serve": "ts-node src/index.ts serve",
    "test": "node --test -r ts-node/register tests/**/*.test.ts"
  },
  "keywords": ["twitter", "bot", "dnd", "ai", "dungeon-master"],
  "license": "MIT",
  "dependencies": {
    "@vercel/node": "5.0.0",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "node-cron": "4.2.1",
    "openai": "6.21.0",
    "twitter-api-v2": "1.29.0",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "@types/node-cron": "3.0.11",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
